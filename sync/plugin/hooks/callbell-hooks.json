{
  "hooks": {
    "SessionStart": [
      { "matcher": "startup|resume|clear|compact",
        "hooks": [ { "type": "command",
          "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/callbell-context.js\"; exit 0",
          "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\callbell-context.js\" }; exit 0",
          "timeout": 5, "statusMessage": "Loading callbell context..." } ] }
    ]
  }
}
