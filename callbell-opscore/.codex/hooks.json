{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \".codex/hooks/callbell-context.js\" --rules; exit 0",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \".codex\\hooks\\callbell-context.js\" --rules }; exit 0",
            "timeout": 5,
            "statusMessage": "Loading project context..."
          }
        ]
      }
    ]
  }
}
