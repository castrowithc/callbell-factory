{
  "templates": ["callbell-devcore", "callbell-opscore"],
  "kinds": {
    "roots":     { "spread": "root" },
    "rules":     { "targets": { "claude": ".claude/rules/" } },
    "context":   { "targets": { "meta": "__callbell__/context/" } },
    "memory":    { "targets": { "meta": "__callbell__/memory/" } },
    "templates": { "targets": { "meta": "__callbell__/templates/" } },
    "skills":    { "targets": { "claude": ".claude/skills/", "codex": ".agents/skills/" } },
    "hooks":     { "targets": { "claude": ".claude/hooks/", "codex": ".codex/hooks/" } }
  },
  "sources": [
    { "from": "sync/all/roots/",     "kind": "roots" },
    { "from": "sync/all/rules/",     "kind": "rules" },
    { "from": "sync/all/context/",   "kind": "context" },
    { "from": "sync/all/memory/",    "kind": "memory" },
    { "from": "sync/all/templates/", "kind": "templates" },
    { "from": "sync/all/skills/",    "kind": "skills" },
    { "from": "sync/all/hooks/",     "kind": "hooks" },
    { "from": "sync/all/zones/_backlog/BACKLOG.md", "to": "__callbell__/_backlog/BACKLOG.md" },
    { "from": "sync/all/zones/_import/.gitkeep",     "to": "__callbell__/_import/.gitkeep" },
    { "from": "sync/all/gitignore",                  "to": ".gitignore" },

    { "from": "sync/devcore/skills/", "kind": "skills", "templates": ["callbell-devcore"] },
    { "from": "sync/devcore/docs/",   "to": "__callbell__/docs/", "templates": ["callbell-devcore"] },

    { "from": "sync/opscore/skills/",    "kind": "skills",    "templates": ["callbell-opscore"] },
    { "from": "sync/opscore/rules/",     "kind": "rules",     "templates": ["callbell-opscore"] },
    { "from": "sync/opscore/templates/", "kind": "templates", "templates": ["callbell-opscore"] },
    { "from": "sync/opscore/framework.md", "to": "__callbell__/framework.md", "templates": ["callbell-opscore"] },

    { "from": "sync/harness/claude/settings.json", "to": ".claude/settings.json" },
    { "from": "sync/harness/codex/hooks.json",     "to": ".codex/hooks.json" }
  ]
}
